# ╔══════════════════════════════════════╗
# ║   JamberTech-WA — Environment Vars  ║
# ╚══════════════════════════════════════╝
# Copy this file to .env and fill in your values

# ── Core ─────────────────────────────────
SESSION_ID=           # Required: DJ~xxx or IK~xxx (get from pairing service)
PREFIX=.              # Command prefix (default: .)
BOT_NAME=JamberTech-WA
MODE=public           # public / private / inbox / groups
TIME_ZONE=Asia/Karachi
VERSION=1.0.0

# ── Owner ─────────────────────────────────
OWNER_NUMBER=923xxxxxxxxx    # Without +
OWNER_NAME=JamberTech
DESCRIPTION=© Powered by JamberTech Official
BOT_MEDIA_URL=              # Optional bot profile image URL

# ── Auto Actions ─────────────────────────
AUTO_REPLY=false         # Auto reply to all messages: true/false
READ_MESSAGE=false       # Auto read messages: true/false
AUTO_REACT=false         # Auto react to messages: true/false
OWNER_REACT=false        # React to owner messages: true/false
ALWAYS_ONLINE=false      # Keep presence online: true/false
AUTO_TYPING=false        # Show typing: true/false/inbox/group
AUTO_RECORDING=false     # Show recording: true/false/inbox/group
AUTO_DOWNLOADER=false    # Auto download media: true/false

# ── Reaction Emojis ───────────────────────
REACT_EMOJIS=❤️,🔥,👍,😍,😂,😮,😎,🥰,👋,💯,✨,⭐,🎉,🤗,😊,💪,👏,✅
OWNER_EMOJIS=👑,💎,⭐,✨,🔥,💯,✅,🎉,🤖,⚡,💫,🌟,🏆

# ── Anti Features ─────────────────────────
ANTI_LINK=true           # true / warn / delete / false
ANTI_DELETE=true         # true / false
ANTI_DELETE_PATH=inbox   # inbox / group / all
ANTI_EDIT=false          # true / false
ANTIEDIT_PATH=inbox      # inbox / group / all
ANTI_CALL=false          # true / false
REJECT_MSG=*📞 Call not allowed. 📵*
ANTIBAD=false
BAD_WORDS=

# ── Status ────────────────────────────────
AUTO_STATUS_SEEN=true    # Auto view statuses: true/false
AUTO_STATUS_REACT=false  # React to statuses: true/false
AUTO_STATUS_REPLY=false  # Reply to statuses: true/false
STATUS_REPLY_MSG=✅ Status Viewed By JamberTech-WA

# ── Welcome / Goodbye ─────────────────────
WELCOME=false
GOODBYE=false
MENTION_REPLY=false
WELCOME_MESSAGE=*_@user joined the group, welcome! 🎉_*
GOODBYE_MESSAGE=*_@user has left the group, we will miss them! 👋_*

# ── Admin ─────────────────────────────────
ADMIN_ACTION=false       # Notify on admin changes: true/false

# ── Sticker ───────────────────────────────
PACK_AUTHOR=JamberTech
PACK_NAME=JamberTech-WA

# ── Nexy AI (Pollinations.AI — No API key needed!) ──
NEXY_CHAT=false          # Enable Nexy AI: true/false
NEXY_NAME=Nexy_JTJarvis  # AI assistant name
NEXY_MODEL=openai        # AI model

# ── Sudo ──────────────────────────────────
SUDO_NUMBERS=            # Comma-separated numbers (without +)
