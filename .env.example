# ============================
#   JamberTech-WA Configuration
# ============================

# Required: Your WhatsApp Session ID
SESSION_ID=

# Required: Your WhatsApp number with country code (no + sign)
OWNER_NUMBER=923XXXXXXXXX

# Optional: Your name
OWNER_NAME=JamberTech

# Optional: Bot display name
BOT_NAME=JamberTech-WA

# Optional: Bot profile picture URL
BOT_PIC=

# Optional: Bot prefix (default: .)
PREFIX=.

# Optional: Bot mode — public / private / inbox / groups
MODE=public

# Optional: Sudo numbers (multiple owners), separated by comma
SUDO_NUMBERS=

# Optional: Auto read WhatsApp statuses — true/false
AUTO_READ_STATUS=true

# Optional: Auto like statuses — true/false
AUTO_LIKE_STATUS=true

# Optional: Auto like emojis (comma separated)
AUTO_LIKE_EMOJIS=💛,❤️,💜,🤍,💙

# Optional: Auto reply to status views — true/false
AUTO_REPLY_STATUS=false

# Optional: Message to send when viewing status
STATUS_REPLY_MSG=✅ Status Viewed By JamberTech WA

# Optional: Anti-delete — true / inboxonly / allchats / false
ANTI_DELETE=true

# Optional: Anti-link in groups — true / delete / warn / false
ANTILINK=true

# Optional: Block incoming calls — true/false
ANTICALL=false

# Optional: Anti-bad words — true/false
ANTIBAD=false

# Optional: Bad words list (comma separated)
BAD_WORDS=

# Optional: Anti-call message
ANTICALL_MSG=*_📞 Auto Call Reject Mode Active. 📵 No Calls Allowed!_*

# Optional: Auto react to messages — true/false
AUTO_REACT=false

# Optional: Auto change bio — true/false
AUTO_BIO=false

# Optional: Auto bio text
AUTO_BIO_QUOTE=Powered by JamberTech

# Optional: Chat bot — true / inbox / groups / false
CHAT_BOT=false

# ============================
#   Nexy_JTJarvis AI Settings
# ============================

# Enable Nexy AI — true / false
# Commands: .ai [message] or .nexy [message]
NEXY_CHAT=false

# Nexy AI assistant name (default: Nexy_JTJarvis)
NEXY_NAME=Nexy_JTJarvis

# Optional: Welcome new members in groups — true/false
WELCOME=false

# Optional: Goodbye message for leaving members — true/false
GOODBYE=false

# Optional: Auto read all messages (blue tick) — true / commands / false
AUTO_READ_MESSAGES=false

# Optional: Presence status — online / typing / recording / null
PRESENCE=online

# Optional: Your timezone
TIME_ZONE=Asia/Karachi

# Optional: Bot version
VERSION=1.0.0
